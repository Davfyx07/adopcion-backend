# ── SERVIDOR ──────────────────────────────────────
PORT=3000

# ── BASE DE DATOS (PostgreSQL) ────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=furmatch
DB_USER=postgres
DB_PASSWORD=tu_password_de_postgres
# Pool de pg (usado internamente por el adapter de Prisma)
DB_URL=postgres://postgres:tu_password_de_postgres@localhost:5432/furmatch
# Cadena de conexión para Prisma ORM (requiere comillas)
DATABASE_URL="postgresql://postgres:tu_password_de_postgres@localhost:5432/furmatch?schema=public"

# ── SEGURIDAD Y JWT ──────────────────────────────────
JWT_SECRET=tu_secreto_jwt_seguro
JWT_EXPIRES_IN=24h
# Contraseña para los usuarios de prueba (seed)
SEED_PASSWORD=FurMatch2025!

# ── SMTP — Recuperación de contraseña (opcional) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_app_password

# ── CLOUDINARY — Subida de imágenes (opcional) ─────
CLOUD_NAME=tu_cloud_name
CLOUD_KEY=tu_api_key
CLOUD_SECRET=tu_api_secret

# ── MATCHING ──────────────────────────────────────
# Umbral mínimo de compatibilidad para mostrar matches (porcentaje 0-100)
MATCH_UMBRAL_COMPATIBILIDAD=30
