# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================
PORT=3000

# ============================================
# BASE DE DATOS (PostgreSQL via Prisma)
# ============================================
# Una sola variable — Prisma maneja la conexión.
# Formato: postgresql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_BD?schema=public
DATABASE_URL="postgresql://postgres:tu_password@localhost:5432/furmatch?schema=public"

# ============================================
# SEGURIDAD Y JWT
# ============================================
JWT_SECRET=tu_secreto_jwt_seguro
JWT_EXPIRES_IN=24h

# Contraseña para los usuarios de prueba (seed)
# ⚠️ OBLIGATORIA — el seed falla si no está definida
SEED_PASSWORD=FurMatch2025!

# ============================================
# CONFIGURACIÓN SMTP (Nodemailer)
# ============================================
# Si no configurás esto, el endpoint /auth/forgot-password falla,
# pero el resto de la app funciona normalmente.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_app_password

# ============================================
# CLOUDINARY (subida de imágenes)
# ============================================
# 1. Crear cuenta gratuita en: https://cloudinary.com/users/register_free
# 2. Ir al Dashboard → "Product Environment Credentials"
# 3. Cada desarrollador usa SU propia cuenta (free tier: 25GB storage)
# 4. Si dejás los placeholders (tu_*), el sistema usa URLs mock para desarrollo
CLOUD_NAME=tu_cloud_name
CLOUD_KEY=tu_api_key
CLOUD_SECRET=tu_api_secret
