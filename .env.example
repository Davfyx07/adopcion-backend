# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================
PORT=3000

# ============================================
# CONFIGURACIÓN DE BASE DE DATOS (PostgreSQL)
# ============================================
DB_HOST=tu_servidor.postgres.database.azure.com
DB_PORT=5432
DB_NAME=nombre_base_datos
DB_USER=usuario
DB_PASSWORD=contraseña

# Cadena de conexión completa (usada por el Pool de pg)
DB_URL=postgres://usuario:contraseña@tu_servidor.postgres.database.azure.com:5432/nombre_base_datos?sslmode=require

# Cadena de conexión para Prisma ORM
DATABASE_URL="postgresql://usuario:contraseña@host:5432/nombre_base_datos?schema=public"

# ============================================
# SEGURIDAD Y JWT
# ============================================
JWT_SECRET=
JWT_EXPIRES_IN=24h

# ============================================
# CONFIGURACIÓN SMTP (Nodemailer)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_app_password

# ============================================
# CLOUDINARY (subida de imágenes)
# ============================================
CLOUD_NAME=tu_cloud_name
CLOUD_KEY=tu_api_key
CLOUD_SECRET=tu_api_secret

# ============================================
# FIREBASE STORAGE (subida de imágenes)
# ============================================
# Opción 1: Path al archivo de service account JSON descargado del Firebase Console
FIREBASE_SERVICE_ACCOUNT_PATH=./config/furmatch-app-dev-firebase-adminsdk.json

# Opción 2: Contenido del JSON como string (para servicios cloud)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Opción 3: Usar Application Default Credentials (solo en GCP/Azure con IAM)
# GOOGLE_APPLICATION_CREDENTIALS=./config/furmatch-app-dev-firebase-adminsdk.json

# Storage bucket (generalmente: proyecto-id.appspot.com)
FIREBASE_STORAGE_BUCKET=furmatch-app-dev.appspot.com
